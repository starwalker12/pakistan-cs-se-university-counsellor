# DigiCounsellor — Environment Variables
#
# All variables are optional. Defaults are set in backend/app.py.

# Ollama (primary LLM provider)
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=gemma4:latest
OLLAMA_TIMEOUT=45

# LM Studio (optional LLM provider)
LM_STUDIO_URL=http://localhost:1234/v1/chat/completions
LM_STUDIO_MODEL=gemma

# Provider priority (comma-separated)
PROVIDER_ORDER=ollama,lm_studio,fallback

# Demo mode settings
FAST_MODE=true
OLLAMA_NUM_PREDICT=700
