# OpenRouter API Key (required for online AI on Vercel)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Model to use with OpenRouter (optional)
# Default: openai/gpt-4o-mini
# Other options: google/gemini-2.0-flash-001, meta-llama/llama-3.1-8b-instruct
# You can change this anytime in Vercel environment settings
OPENROUTER_MODEL=openai/gpt-4o-mini
